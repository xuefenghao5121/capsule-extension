{
  "name": "@openclaw/capsule",
  "version": "1.0.0",
  "description": "Capsule - Sandbox-centric Security Extension for OpenClaw (Kunpeng Optimized)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@openclaw/core": "workspace:*",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "tools": [
      "exec_sandbox",
      "sandbox_create",
      "sandbox_destroy",
      "capability_check",
      "capability_grant",
      "capability_revoke",
      "quota_check",
      "quota_record",
      "attestation"
    ],
    "docsPath": "/extensions/capsule",
    "docsLabel": "capsule"
  },
  "keywords": [
    "openclaw",
    "extension",
    "security",
    "sandbox",
    "kunpeng",
    "trustzone",
    "mte",
    "pac"
  ],
  "author": "Taiwei Team",
  "license": "MIT"
}